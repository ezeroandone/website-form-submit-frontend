# ─── Backend API URL ───────────────────────────────────────────
# Points to the Cloudflare Worker
# Production:  https://api.formsend.ezeroandone.io
# Local dev:   http://localhost:8787
NEXT_PUBLIC_API_URL=https://api.formsend.ezeroandone.io
